{
  "info": {
    "name": "School Management API",
    "description": "APIs to manage schools and list them by proximity.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Add School",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Greenwood High\",\n  \"address\": \"123, Tech Street, City\",\n  \"latitude\": 12.9716,\n  \"longitude\": 77.5946\n}"
        },
        "url": {
          "raw": "{{base_url}}/addSchool",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "addSchool"
          ]
        }
      },
      "response": []
    },
    {
      "name": "List Schools by Proximity",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/listSchools?latitude=12.9716&longitude=77.5946",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "listSchools"
          ],
          "query": [
            {
              "key": "latitude",
              "value": "12.9716"
            },
            {
              "key": "longitude",
              "value": "77.5946"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get All Schools (Bonus)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/allSchools",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "allSchools"
          ]
        }
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    }
  ]
}
